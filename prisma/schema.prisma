generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String      @unique
  password      String? 
  role          String      @default("EMPLOYEE") // EMPLOYEE, HR, MANAGER, ADMIN
  department    String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  siteId        String?
  site          Site?       @relation(fields: [siteId], references: [id])
  
  grievances    Grievance[] @relation("EmployeeGrievances")
  assignedTo    Grievance[] @relation("AssignedGrievances")
  comments      Comment[]
}

model Site {
  id          String      @id @default(cuid())
  name        String      @unique
  code        String?     @unique
  location    String?
  
  users       User[]
  grievances  Grievance[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Category {
  id          String      @id @default(cuid())
  name        String      @unique 
  description String?
  grievances  Grievance[]
}

model Grievance {
  id           String    @id @default(cuid())
  ticketNumber String    @unique 
  
  employeeId   String? 
  employee     User?     @relation("EmployeeGrievances", fields: [employeeId], references: [id], onDelete: SetNull)
  
  assignedToId String?
  assignedTo   User?     @relation("AssignedGrievances", fields: [assignedToId], references: [id], onDelete: SetNull)
  
  siteId       String?
  site         Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  
  // Fields aligned with Excel Template
  empIdGatepass   String?
  location        String?   // Legacy, kept for backwards compatibility, but siteId is preferred
  grievantName    String?
  grievantContact String?
  concernedPerson String?
  issue           String?
  currentStatus   String?   @default("PENDING")
  sentiment       String?
  solved          String?   @default("PENDING")
  dateResolved    DateTime?
  remark          String?
  
  categoryId   String?
  category     Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  department   String?
  priority     String    @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  status       String    @default("SUBMITTED") // SUBMITTED, UNDER_REVIEW, INVESTIGATION, ACTION_TAKEN, RESOLVED, CLOSED, REJECTED
  
  subject      String?
  description  String?
  isAnonymous  Boolean   @default(false)
  
  rejectionReason String?
  
  escalationLevel Int       @default(0)
  slaDueDate      DateTime?
  
  satisfactionScore    Int?
  satisfactionFeedback String?
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  comments     Comment[]
  logs         GrievanceLog[]
  attachments  Attachment[]
}

model Attachment {
  id          String    @id @default(cuid())
  url         String
  fileType    String?
  fileName    String?
  
  grievanceId String
  grievance   Grievance @relation(fields: [grievanceId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
}

model Comment {
  id          String    @id @default(cuid())
  content     String
  
  grievanceId String
  grievance   Grievance @relation(fields: [grievanceId], references: [id], onDelete: Cascade)
  
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  isInternal  Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
}

model GrievanceLog {
  id          String    @id @default(cuid())
  grievanceId String
  grievance   Grievance @relation(fields: [grievanceId], references: [id], onDelete: Cascade)
  
  changedBy   String?   // "SYSTEM", "PUBLIC", or User Name
  action      String    // e.g., "STATUS_CHANGED", "ASSIGNED"
  details     String?   // JSON string or text details
  
  createdAt   DateTime  @default(now())
}
